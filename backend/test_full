// ============================================
// RUN ALL TESTS
// ============================================
async function runAllTests() {
  log('========================================', 'INFO');
  log('ERP SYSTEM COMPREHENSIVE TEST SUITE', 'INFO');
  log('========================================', 'INFO');
  
  const startTime = Date.now();
  
  try {
    await testMasterModules();
    await testStockModules();
    await testPurchaseModules();
    await testSalesModules();
    await testGrindModules();
    await testLedgerModules();
    await testReportModules();
    await testAuthModules();
    await testAdditionalModules();
  } catch (error) {
    log(`Fatal error: ${error.message}`, 'FATAL');
  }
  
  const endTime = Date.now();
  const duration = (endTime - startTime) / 1000;
  
  log('========================================', 'INFO');
  log('TEST SUMMARY', 'INFO');
  log(`✅ Passed: ${testsPassed}`, 'INFO');
  log(`❌ Failed: ${testsFailed}`, 'INFO');
  log(`⏱ Duration: ${duration}s`, 'INFO');
  log('========================================', 'INFO');
  
  // Show failed tests
  if (testsFailed > 0) {
    log('FAILED TESTS:', 'FAIL');
    testResults.filter(t => t.status === 'FAIL').forEach(t => {
      log(`  - ${t.name}: ${t.error}`, 'FAIL');
    });
  }
  
  process.exit(testsFailed > 0 ? 1 : 0);
}

runAllTests();
